# System
SECRET_KEY=dev-key-keep-it-safe
APP_NAME=資產管理系統
BASE_URL=http://localhost:5520

# Database
# For SQLite (default):
DATABASE_URL=sqlite:///data/asset.db
# For PostgreSQL (Docker):
# DATABASE_URL=postgresql://admin:password123@localhost:5432/asset_management

# Auth
JWT_SECRET_KEY=jwt-secret-keep-it-safe

# Module Switches
DOCUMENT_MODULE_ENABLED=true
WATERMARK_ENABLED=true
FULLTEXT_SEARCH_ENABLED=true

# Inventory & Workflow
INVENTORY_PHOTO_REQUIRED=true
INVENTORY_GPS_REQUIRED=true
TRANSFER_SENIOR_APPROVAL=true
DISPOSAL_SENIOR_APPROVAL=true

# Scheduler
APPROVAL_REMINDER_DAYS=3
APPROVAL_ESCALATION_DAYS=7
